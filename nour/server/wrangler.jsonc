{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "nour-assistant",
  "main": "cloudflare-worker.js",
  "compatibility_date": "2026-07-24",
  "workers_dev": true,
  "vars": {
    "NOUR_ENV": "production",
    "NOUR_ALLOWED_ORIGINS": "https://malickgueye630-dotcom.github.io",
    "LLM_PROVIDER_NAME": "OpenAI-compatible",
    "LLM_BASE_URL": "https://api.openai.com/v1",
    "LLM_MODEL": "A_CONFIGURER",
    "LLM_TIMEOUT_MS": "30000"
  },
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      "namespace_id": "2026072401",
      "simple": {
        "limit": 20,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  }
}
